{
  "extends": "stylelint-config-standard-scss",
  "plugins": [
    "stylelint-selector-bem-pattern"
  ],
  "rules": {
    "selector-class-pattern": null,

    "plugin/selector-bem-pattern": {
      "componentName": "[a-z]+(?:-[a-z]+)*",
      "componentSelectors": {
        "initial": "^\\.{componentName}(?:--[a-z]+(?:-[a-z]+)*)?$",
        "combined": "^\\.{componentName}__[a-z]+(?:-[a-z]+)*(?:--[a-z]+(?:-[a-z]+)*)?$"
      },
      "utilitySelectors": "^\\.u-[a-z-]+$",
      "ignoreSelectors": [
        "html",
        "body",
        "^\\.container",
        "^\\.row",
        "^\\.col",
        "^\\.btn",
        "^\\.card",
        "^\\.nav",
        "^\\.navbar",
        "^\\.form-",
        "^\\.modal",
        "^\\.alert",
        "^\\.badge",
        "^\\.dropdown",
        "^\\.offcanvas",
        "^\\.accordion",
        "^\\.carousel",
        "^\\.d-",
        "^\\.p-",
        "^\\.px-",
        "^\\.py-",
        "^\\.pt-",
        "^\\.pb-",
        "^\\.ps-",
        "^\\.pe-",
        "^\\.m-",
        "^\\.mx-",
        "^\\.my-",
        "^\\.mt-",
        "^\\.mb-",
        "^\\.ms-",
        "^\\.me-",
        "^\\.g-"
      ]
    }
  }
}